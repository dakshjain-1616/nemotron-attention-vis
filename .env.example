# Nemotron Attention Visualizer — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Model Configuration ─────────────────────────────────────────────────────

# HuggingFace model ID to visualize attention for.
# Default: nvidia/Nemotron-Cascade-2-30B-A3B (large — requires GPU + HF_TOKEN)
# Lightweight alternatives for CPU testing:
#   Qwen/Qwen3-0.6B        (600M params — recommended for CPU)
#   Qwen/Qwen3-1.7B        (1.7B params)
#   Qwen/Qwen2.5-1.5B-Instruct
#   facebook/opt-125m      (125M params — tiny, great for CI)
MODEL_NAME=nvidia/Nemotron-Cascade-2-30B-A3B

# HuggingFace Hub access token.
# Required to download gated/private models (e.g. Nemotron, Llama).
# Obtain at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Device to run inference on: "cuda", "cpu", or "mps" (Apple Silicon).
# Defaults to "cuda" when a GPU is available, else "cpu".
DEVICE=cuda

# Small model to fall back to if the primary model fails to load.
# Set to a small open model so --real mode degrades gracefully on CPU.
# Qwen/Qwen3-0.6B is the recommended default: open-weight, ~1.2 GB.
FALLBACK_MODEL=Qwen/Qwen3-0.6B

# ─── Inference Settings ──────────────────────────────────────────────────────

# Maximum number of tokens to feed to the model.
# Larger values increase memory usage quadratically for attention extraction.
MAX_TOKENS=128

# Comma-separated list of transformer layer indices to visualize.
# Leave empty to visualize all attention layers.
# Example: LAYER_FILTER=0,1,2,3
LAYER_FILTER=

# ─── Output Settings ─────────────────────────────────────────────────────────

# Directory where output files (HTML, JSON, CSV) are saved.
OUTPUT_DIR=outputs

# Name of the generated HTML attention map file.
OUTPUT_HTML=attention_map.html

# Name of the generated raw attention data JSON file.
OUTPUT_JSON=attention_data.json

# Color scale for the heatmap. Any Plotly sequential colorscale name:
# Viridis, Plasma, Blues, Reds, YlOrRd, Hot, ...
COLOR_SCALE=Viridis

# Set to "true" to also export a CSV of per-layer per-head statistics
# (entropy, max weight, Gini coefficient) alongside the JSON output.
EXPORT_CSV=false

# ─── Mock / Demo Mode ────────────────────────────────────────────────────────

# Set to "true" to run in mock mode (no model download needed).
# Auto-detected by demo.py when HF_TOKEN is not set and model is large.
MOCK_MODE=false

# Seed for reproducible mock attention data generation.
MOCK_SEED=42

# ─── Reliability Settings ────────────────────────────────────────────────────

# Number of retries on transient model load errors (e.g. network timeouts).
# Uses exponential backoff: 1s, 2s, 4s between attempts.
LOAD_RETRIES=2

# ─── UI / Rendering ──────────────────────────────────────────────────────────

# Plotly.js CDN version used in generated HTML files.
# Check https://github.com/plotly/plotly.js/releases for latest releases.
PLOTLY_CDN_VERSION=2.27.0

# ─── Demo Settings ───────────────────────────────────────────────────────────

# Number of simulated attention layers when running in mock mode.
DEMO_NUM_LAYERS=8

# Number of simulated attention heads per layer in mock mode.
DEMO_NUM_HEADS=16
